{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://tailstory.wiki/toc-schema.json",
    "title": "Tailstory wiki TOC",
    "type": "object",
    "additionalProperties": false,
    "required": ["entries"],
    "properties": {
        "entries": {
            "type": "array",
            "minItems": 1,
            "items": {
                "oneOf": [
                    { "$ref": "#/$defs/leaf" },
                    { "$ref": "#/$defs/section" }
                ]
            }
        }
    },
    "$defs": {
        "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-/]*$"
        },
        "leaf": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "page"],
            "properties": {
                "title": { "type": "string", "minLength": 1 },
                "page": { "$ref": "#/$defs/slug" }
            }
        },
        "section": {
            "type": "object",
            "additionalProperties": false,
            "required": ["section", "pages"],
            "properties": {
                "section": { "type": "string", "minLength": 1 },
                "pages": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "$ref": "#/$defs/leaf" }
                }
            }
        }
    }
}
